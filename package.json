{
  "name": "devpilot-ai",
  "version": "1.0.0",
  "description": "AI-powered DevOps Project Management SaaS platform",
  "main": "index.js",
  "workspaces": ["apps/*", "services/*"],
  "scripts": {
    "start": "npm --prefix apps/api-gateway start",
    "dev": "npm --prefix apps/frontend run dev",
    "dev:api": "npm --prefix apps/api-gateway start",
    "build": "npm --prefix apps/api-gateway run build && npm --prefix apps/frontend run build",
    "seed": "npm --prefix apps/api-gateway run seed",
    "monitoring": "docker compose -f docker-compose.monitoring.yml up",
    "test": "jest",
    "scaffold:generate": "node scripts/generate_scaffold.js"
  },
  "dependencies": {
    "axios": "^0.21.1",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^5.10.9"
  },
  "devDependencies": {
    "@types/express": "^4.17.8",
    "@types/jest": "^26.0.20",
    "@types/node": "^14.14.31",
    "jest": "^26.6.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/devpilot-ai.git"
  },
  "keywords": [
    "devops",
    "project management",
    "saas",
    "ai"
  ],
  "author": "Your Name",
  "license": "MIT"
}
